{
	"layer":"top",
	"position":"top",
	"modules-left":["hyprland/workspaces"],
	"modules-center":["clock"],
	"modules-right":["pulseaudio", "network", "cpu", "memory", "tray"],

	"clock": {
		"format": "{:%H:%M}"
	},
	"cpu": {
		"format":"CPU {usage}%"
	},
	"memory": {
		"format":"RAM {}%"
	},
	"pulseaudio":{
		"format":"VOL {volume}%",
		"format-muted":"MUTED"
	},
	"network":{
		"format-wifi":"WIFI {signalStrength}%",
		"format-ethernet":"ETH",
		"format-disconnectted":"OFFLINE",
		"tooltip-format":"{ifname}"
	},
	"tray":{
		"spacing":10
	}
}

