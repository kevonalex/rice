#!/usr/bin/env bash

PROFILE="$1"
DOTFILES="$HOME/dotfiles/profiles/$PROFILE/.config"

if [ -z "$PROFILE" ]; then
    echo "Usage: rice <profile>"
    exit 1
fi

if [ ! -d "$DOTFILES" ]; then
    echo "Profile '$PROFILE' not found."
    exit 1
fi

echo "Applying rice: $PROFILE"

for dir in "$DOTFILES"/*; do
    name=$(basename "$dir")
    rm -rf "$HOME/.config/$name"
    ln -s "$dir" "$HOME/.config/$name"
done

# reload components
pkill waybar 2>/dev/null
waybar &

hyprctl reload

echo "Rice '$PROFILE' loaded."
